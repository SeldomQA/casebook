{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "metadata",
    "test_cases"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": [
        "module",
        "feature",
        "owner",
        "last_reviewed"
      ],
      "properties": {
        "module": {
          "type": "string",
          "description": "Parent module"
        },
        "feature": {
          "type": "string",
          "description": "Focused feature for this file"
        },
        "owner": {
          "type": "string",
          "description": "Owner, preferably an English name"
        },
        "last_reviewed": {
          "type": "string",
          "format": "date",
          "description": "Last review date (YYYY-MM-DD)"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "File-level tags"
        }
      },
      "additionalProperties": false
    },
    "test_cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "steps",
          "expected_results",
          "priority",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^TC_[A-Z0-9_]{3,}_[0-9]{3}$",
            "description": "Globally unique ID, format TC_<FEATURE_PREFIX>_<NNN>"
          },
          "title": {
            "type": "string",
            "description": "Concise action-oriented title"
          },
          "description": {
            "type": "string",
            "description": "Additional description (optional)"
          },
          "priority": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2"
            ],
            "description": "Priority"
          },
          "type": {
            "type": "string",
            "enum": [
              "functional",
              "ui",
              "security",
              "performance",
              "accessibility",
              "business",
              "other",
              "data-consistency"
            ],
            "description": "Case type"
          },
          "preconditions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Preconditions (optional)"
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "description": "Execution steps, one action per item"
          },
          "expected_results": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "description": "Expected results, one or more items"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Case-level tags"
          },
          "auto": {
            "type": "boolean",
            "default": false,
            "description": "Whether the case is planned for automation (default false)"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
